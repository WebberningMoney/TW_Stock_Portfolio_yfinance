# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
.conda/

# Local environment and secrets
.env
.env.*
!.env.example

# Local application data
data/*
!data/.gitkeep
exports/*
!exports/.gitkeep
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
yfinance_cache/

# IDE and operating-system files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Build and packaging output
build/
dist/
*.egg-info/
*.spec

# Logs and temporary files
*.log
*.tmp
*.bak
~*
